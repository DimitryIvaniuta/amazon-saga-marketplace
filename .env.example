# Tail-latency and hot-product tuning
INVENTORY_DB_ACQUIRE_TIMEOUT=1s
INVENTORY_KAFKA_CONCURRENCY=6
CATALOG_LOCAL_CACHE_MAX_SIZE=10000
CATALOG_DB_ACQUIRE_TIMEOUT=750ms
CATALOG_REDIS_TIMEOUT=250ms
CATALOG_LOCAL_CACHE_TTL=20s
CATALOG_REDIS_CACHE_TTL=5m
CATALOG_NEGATIVE_CACHE_TTL=30s
CATALOG_CACHE_LOAD_TIMEOUT=1s
CATALOG_CACHE_LOCK_TTL=5s
CATALOG_CACHE_LOCK_WAIT=250ms
CATALOG_CACHE_POLL_INTERVAL=20ms
CATALOG_CACHE_TTL_JITTER=0.15
CATALOG_ROUTE_RATE=5000
CATALOG_ROUTE_BURST=10000
CATALOG_HOT_KEY_RATE=500
CATALOG_HOT_KEY_BURST=1000
GATEWAY_CONNECT_TIMEOUT_MS=1000
GATEWAY_RESPONSE_TIMEOUT=5s
GATEWAY_MAX_CONNECTIONS=500
GATEWAY_POOL_ACQUIRE_TIMEOUT_MS=1000
GATEWAY_REDIS_TIMEOUT=250ms
CATALOG_CONNECT_TIMEOUT_MS=500
CATALOG_RESPONSE_TIMEOUT_MS=1500
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-secret
